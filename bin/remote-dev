#!/usr/bin/env bash
set -Eeuo pipefail

CONFIG_DIR="${HOME}/.config/remote-dev"
STATE_DIR="${HOME}/.local/state/remote-dev"
CONFIG_FILE="${CONFIG_DIR}/config.env"
PORTS_FILE="${CONFIG_DIR}/serve-ports"

if [[ -f "${STATE_DIR}/install.env" ]]; then
  # shellcheck disable=SC1090
  source "${STATE_DIR}/install.env"
fi

if [[ -f "${CONFIG_FILE}" ]]; then
  # shellcheck disable=SC1090
  source "${CONFIG_FILE}"
fi

log() {
  printf '\033[1;36m[remote-dev]\033[0m %s\n' "$*"
}

warn() {
  printf '\033[1;33m[remote-dev]\033[0m %s\n' "$*" >&2
}

die() {
  printf '\033[1;31m[remote-dev]\033[0m %s\n' "$*" >&2
  exit 1
}

usage() {
  cat <<'EOF'
Usage: remote-dev <command> [arguments]

Commands:
  doctor          Show installed tools, versions, and pending actions
  update          Pull bootstrap updates and rerun the installed profile
  setup           Rerun the installed profile
  tailscale       Authenticate Tailscale and configure standard ports (generic)
  serve [ports]   Configure private Tailscale Serve endpoints (generic)
  unserve [ports] Remove private Tailscale Serve endpoints (generic)
  ports           Show configured ports
  codex <action>  Start, pair, or stop Codex remote control
  shell           Start a fresh Zsh login shell
  help            Show this help
EOF
}

load_state() {
  [[ -f "${STATE_DIR}/install.env" ]] || die "Install state not found. Rerun bootstrap.sh."
  # shellcheck disable=SC1090
  source "${STATE_DIR}/install.env"
  [[ -d "${REMOTE_DEV_INSTALL_DIR:-}" ]] || die "Installed repository not found."
}

configured_ports() {
  [[ -f "${PORTS_FILE}" ]] || return 0
  sed -E 's/[[:space:]]*#.*$//' "${PORTS_FILE}" |
    awk 'NF && $1 ~ /^[0-9]+$/ { print $1 }'
}

tailscale_hostname() {
  if [[ -n "${REMOTE_DEV_TAILSCALE_HOSTNAME:-}" ]]; then
    printf '%s\n' "${REMOTE_DEV_TAILSCALE_HOSTNAME}"
  else
    printf 'dev-%s\n' "$(hostname -s | tr '[:upper:]_' '[:lower:]-')"
  fi
}

tailscale_is_connected() {
  tailscale status >/dev/null 2>&1
}

tailscale_connect() {
  command -v tailscale >/dev/null 2>&1 || die "Tailscale is not installed."

  if tailscale_is_connected; then
    log "Tailscale is already connected."
    return 0
  fi

  local hostname_value
  local -a args
  local key_file=""

  hostname_value="$(tailscale_hostname)"
  args=(up "--hostname=${hostname_value}")

  if [[ -n "${REMOTE_DEV_TAILSCALE_TAGS:-}" ]]; then
    args+=("--advertise-tags=${REMOTE_DEV_TAILSCALE_TAGS}")
  fi

  if [[ "${REMOTE_DEV_ENABLE_TAILSCALE_SSH:-0}" == "1" ]]; then
    args+=(--ssh)
  fi

  if [[ -n "${TS_AUTH_KEY:-}" ]]; then
    key_file="$(mktemp)"
    chmod 600 "${key_file}"
    printf '%s' "${TS_AUTH_KEY}" > "${key_file}"
    trap 'rm -f "${key_file}"' EXIT
    args+=("--auth-key=file:${key_file}")
  fi

  sudo tailscale "${args[@]}"

  if [[ -n "${key_file}" ]]; then
    rm -f "${key_file}"
    trap - EXIT
  fi
}

serve_ports() {
  command -v tailscale >/dev/null 2>&1 || die "Tailscale is not installed."
  tailscale_is_connected || die "Tailscale is not connected. Run: remote-dev tailscale"

  local -a ports
  local port

  if [[ $# -gt 0 ]]; then
    ports=("$@")
  else
    mapfile -t ports < <(configured_ports)
  fi

  [[ ${#ports[@]} -gt 0 ]] || die "No ports configured."

  for port in "${ports[@]}"; do
    [[ "${port}" =~ ^[0-9]+$ ]] || die "Invalid port: ${port}"
    log "Serving 127.0.0.1:${port} privately on HTTPS port ${port}..."
    sudo tailscale serve --bg --https="${port}" "http://127.0.0.1:${port}"
  done

  tailscale serve status
}

unserve_ports() {
  command -v tailscale >/dev/null 2>&1 || die "Tailscale is not installed."

  local -a ports
  local port

  if [[ $# -gt 0 ]]; then
    ports=("$@")
  else
    mapfile -t ports < <(configured_ports)
  fi

  [[ ${#ports[@]} -gt 0 ]] || die "No ports configured."

  for port in "${ports[@]}"; do
    [[ "${port}" =~ ^[0-9]+$ ]] || die "Invalid port: ${port}"
    log "Removing private HTTPS endpoint on port ${port}..."
    sudo tailscale serve --https="${port}" off
  done
}

version_or_missing() {
  local command_name="$1"
  local output=""
  shift

  if command -v "${command_name}" >/dev/null 2>&1; then
    output="$("$@" 2>/dev/null || true)"
    printf '\033[32m%-12s\033[0m %s\n' "${command_name}" "${output%%$'\n'*}"
  else
    printf '\033[33m%-12s\033[0m %s\n' "${command_name}" "not installed"
  fi
}

doctor() {
  printf 'Remote development environment\n'
  printf '==============================\n\n'
  printf 'Platform: %s\n' "${REMOTE_DEV_PLATFORM:-generic}"
  printf 'Delivery: %s\n\n' "${REMOTE_DEV_DELIVERY:-script}"

  version_or_missing git git --version
  version_or_missing zsh zsh --version
  version_or_missing tmux tmux -V
  version_or_missing python python --version
  version_or_missing uv uv --version
  version_or_missing node node --version
  version_or_missing yarn yarn --version
  version_or_missing docker docker --version
  version_or_missing gh gh --version
  version_or_missing gcloud gcloud --version
  version_or_missing forge forge --version
  version_or_missing codex codex --version
  version_or_missing tailscale tailscale version

  printf '\n'
  if command -v docker >/dev/null 2>&1; then
    if id -nG | tr ' ' '\n' | grep -qx docker; then
      printf '\033[32mDocker group\033[0m active\n'
    else
      printf '\033[33mDocker group\033[0m log out and back in to activate\n'
    fi
  fi

  if [[ "${REMOTE_DEV_PLATFORM:-generic}" == "exe-dev" ]]; then
    printf '\033[32mexe.dev proxy\033[0m private HTTPS ports 3000-9999\n'
    printf '  Bind servers to 0.0.0.0 and open https://%s.exe.xyz:<port>/\n' "$(hostname -s)"
  elif command -v tailscale >/dev/null 2>&1; then
    if tailscale_is_connected; then
      printf '\033[32mTailscale\033[0m connected as %s\n' "$(tailscale_hostname)"
      tailscale serve status 2>/dev/null || true
    else
      printf '\033[33mTailscale\033[0m run: remote-dev tailscale\n'
    fi
  fi

  if command -v gh >/dev/null 2>&1 && ! gh auth status >/dev/null 2>&1; then
    printf '\033[33mGitHub\033[0m run: gh auth login\n'
  fi

  if command -v gcloud >/dev/null 2>&1 && ! gcloud auth list --filter=status:ACTIVE --format='value(account)' 2>/dev/null | grep -q .; then
    printf '\033[33mGoogle Cloud\033[0m run: gcloud auth login\n'
  fi
}

install_arguments() {
  if [[ "${REMOTE_DEV_PLATFORM:-generic}" == "exe-dev" ]]; then
    INSTALL_ARGS=(--preset exe-dev)
  else
    INSTALL_ARGS=(--profile "${REMOTE_DEV_PROFILE:-full}")
  fi
  [[ "${REMOTE_DEV_INSTALL_DOCKER:-1}" == "1" ]] || INSTALL_ARGS+=(--without-docker)
  [[ "${REMOTE_DEV_INSTALL_GCLOUD:-1}" == "1" ]] || INSTALL_ARGS+=(--without-gcloud)
  [[ "${REMOTE_DEV_INSTALL_FOUNDRY:-1}" == "1" ]] || INSTALL_ARGS+=(--without-foundry)
  [[ "${REMOTE_DEV_INSTALL_CODEX:-1}" == "1" ]] || INSTALL_ARGS+=(--without-codex)
  [[ "${REMOTE_DEV_INSTALL_TAILSCALE:-1}" == "1" ]] || INSTALL_ARGS+=(--without-tailscale)
}

rerun_setup() {
  load_state
  install_arguments
  export REMOTE_DEV_PLATFORM="${REMOTE_DEV_PLATFORM:-generic}"
  export REMOTE_DEV_DELIVERY="${REMOTE_DEV_DELIVERY:-script}"
  exec "${REMOTE_DEV_INSTALL_DIR}/install.sh" "${INSTALL_ARGS[@]}"
}

update_installation() {
  load_state
  if [[ "${REMOTE_DEV_DELIVERY:-script}" == "image" ]]; then
    die "This installation is managed by its Docker image. Build or select a newer image instead."
  fi
  if [[ -d "${REMOTE_DEV_INSTALL_DIR}/.git" ]]; then
    if git -C "${REMOTE_DEV_INSTALL_DIR}" symbolic-ref -q HEAD >/dev/null 2>&1; then
      git -C "${REMOTE_DEV_INSTALL_DIR}" pull --ff-only
    else
      warn "Installation is pinned at ${REMOTE_DEV_SOURCE_REF:-a detached revision}; not pulling updates."
    fi
  else
    die "Installed repository is not a Git checkout."
  fi
  install_arguments
  export REMOTE_DEV_PLATFORM="${REMOTE_DEV_PLATFORM:-generic}"
  export REMOTE_DEV_DELIVERY="${REMOTE_DEV_DELIVERY:-script}"
  exec "${REMOTE_DEV_INSTALL_DIR}/install.sh" "${INSTALL_ARGS[@]}"
}

codex_remote_control() {
  command -v codex >/dev/null 2>&1 || die "Codex is not installed."
  case "${1:-}" in
    start) codex remote-control start ;;
    pair) codex remote-control pair ;;
    stop) codex remote-control stop ;;
    *) die "Usage: remote-dev codex start|pair|stop" ;;
  esac
}

command_name="${1:-help}"
shift || true

case "${command_name}" in
  doctor) doctor ;;
  update) update_installation ;;
  setup) rerun_setup ;;
  tailscale)
    tailscale_connect
    serve_ports
    ;;
  serve) serve_ports "$@" ;;
  unserve) unserve_ports "$@" ;;
  ports) configured_ports ;;
  codex) codex_remote_control "$@" ;;
  shell) exec zsh -l ;;
  help|-h|--help) usage ;;
  *) usage; die "Unknown command: ${command_name}" ;;
esac
